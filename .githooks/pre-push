#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-push: building matplotlib-python binary ==="
cargo build -p matplotlib-python

echo "=== pre-push: running Python tests (smoke test) ==="
# Run dedicated smoke test file — fast collection, no parametric overhead
target/debug/matplotlib-python -m pytest \
  python/matplotlib/tests/test_smoke.py \
  -x -q --tb=short

echo "pre-push passed"
